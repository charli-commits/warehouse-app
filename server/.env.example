DATABASE_URL="file:./dev.db"

# JWT — cambia este valor en producción (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Odoo connection (read-only)
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database_name
ODOO_USER=your_user@example.com
ODOO_API_KEY=your_api_key_here

# GLS España (reserved for future implementation)
GLS_API_URL=https://api.gls-spain.es
GLS_USER=your_gls_user
GLS_PASSWORD=your_gls_password
GLS_CUSTOMER_ID=your_customer_id

PORT=3001
